    "import matplotlib.pyplot as plt\n",
    "plik=open('plik2.txt','r')\n",
    "x=[]\n",
    "y=[]\n",
    "dane=[linia.split(',') for linia in plik]\n",
    "for i in dane[1:]:\n",
